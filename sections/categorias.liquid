<section class="categorias">

  <h2>Compre por Categorias</h2>

  {% assign colecoes_excluidas = 'confira-nossos-produtos,especial-copa-do-mundo' |  split: ',' %}

  <div class="itens">
    {% for collection in collections %}
       {% unless colecoes_excluidas contains collection.handle %}
        <a class="item" href="{{ collection.url }}">
        <p>{{ collection.title }}</p>
        <img src="{{ collection.image | image_url}}" alt="{{ collection.title }}">
      </a>
      {% endunless %}
    {% endfor %}
  </div>

</section>

<style>

  section.categorias {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;

    padding: 30px 80px 0;
  }

  section.categorias h2 {
    font-family: var(--bold);
    font-size: 60px;
    margin: 0 0 30px;

    background: linear-gradient(90deg, var(--cor-verde-principal), var(--cor-verde-principal-hover));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  section.categorias h2::selection {
    background: rgba(0, 0, 0, 0.15);
    color: inherit;
}

  section.categorias .itens {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  section.categorias .itens .item {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    width: calc(20% - 15px);
    padding: 20px;
    margin-top: 40px;

  }

   section.categorias .itens .item:hover {
    background-color: rgba(85, 115, 108, 0.3);
    border-radius: 30px;
    padding: 20px;
    transition: 0.3s ease-in-out;
  }

  section.categorias .itens .item img {
    max-width: 150px;
    margin: 30px;
  }

  section.categorias .itens .item p {
    font-family: var(--light);
    color: var(--cor-verde-principal);
    font-size: 20px;
  }



</style>


<script></script>
